# Font
font-family = 0xProto Nerd Font
font-size = 10

# Window
window-padding-x = 3
window-padding-y = 3
gtk-titlebar = false

# Background
background-opacity = 0.97

# Bell (disable audio)
bell-features = no-system

# Copy/paste (Linux/Wayland)
copy-on-select = clipboard
keybind = shift+insert=paste_from_clipboard

# Font size adjustments
keybind = ctrl+=increase_font_size:2
keybind = ctrl+-=decrease_font_size:2
keybind = shift+ctrl+=increase_font_size:2
keybind = shift+ctrl+-=decrease_font_size:2

# Quick terminal (quake-style)
# Note: global: prefix requires XDG portal (not available on sway).
# For true quake toggle from anywhere, add a sway keybind:
#   bindsym ctrl+grave exec ghostty --class=quake
# and a sway rule: for_window [app_id="quake"] floating enable, move scratchpad
quick-terminal-position = top
quick-terminal-animation-duration = 0.2
quick-terminal-screen = main
# keybind = ctrl+`=toggle_quick_terminal  # add once key syntax confirmed

# Colors - Adapta Nokto Maia
background = #222D31
foreground = #d8d8d8
selection-background = #2B2C2B
selection-foreground = #16A085

palette = 0=#222D31
